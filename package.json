{
  "name": "table-orders",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://LisaBlas.github.io/TableOrders",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --mode demo",
    "build:demo-v2": "vite build --mode demo-v2",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "predeploy:demo": "npm run build:demo",
    "deploy:demo": "gh-pages -d dist-demo --dest demo",
    "predeploy:demo-v2": "npm run build:demo-v2",
    "deploy:demo-v2": "gh-pages -d dist-demo-v2 -r https://github.com/LisaBlas/TableOrders-v2.git",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^6.0.11",
    "vitest": "^4.1.5"
  }
}
